#lang forge/froglet

constraints:
  - orientation:
      selector: next
      directions: [directlyBelow]

  - orientation:
      selector: first
      directions: [directlyBelow]

  - orientation:
      selector: required_courses
      directions: [directlyBelow]

  - orientation:
      selector: concentration
      directions: [directlyLeft]

  - orientation:
      selector: plan
      directions: [directlyRight]

  - size:
      selector: Semester
      width: 150
      height: 150

  - size:
      selector: ConcentrationReqs
      width: 200
      height: 200

  - size:
      selector: Course
      width: 150
      height: 150

directives:
  - atomColor:
      selector: Student
      value: "#02006e"

  - atomColor:
      selector: Semester
      value: "#08a300"

  - atomColor:
      selector: Course
      value: "#fcba03"

  - atomColor:
      selector: ConcentrationReqs
      value: "#8900be"

  - atomColor:
      selector: CoursePlan
      value: "#db1600"

  # Show enrollmentCap as a label on each Course node
  - attribute:
      field: enrollmentCap

  - attribute:
      field: prereqs

  - attribute:
      field: required_courses

  - attribute:
      field: courses

  - flag: hideDisconnectedBuiltIns